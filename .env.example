# Zammad MCP server — environment variables
#
# Copy to .env (not tracked) or paste into the `env` block of your Claude
# Desktop / Claude Code config under mcpServers.<name>.

# Required ----------------------------------------------------------------

# Zammad REST base URL (must include /api/v1/).
ZAMMAD_URL=https://mail.example.com/api/v1/

# Personal API token. Generate in Zammad: Profile → Token Access.
ZAMMAD_HTTP_TOKEN=replace-with-your-token

# Optional ----------------------------------------------------------------

# Own addresses that should be filtered out of CC when building Reply-All
# drafts. Comma-separated. When unset, nothing is filtered.
# ZAMMAD_SELF_EMAILS=support@example.com,me@example.com

# Names that must not appear in reply_html (because the signature already
# supplies them). Comma-separated, matched case-sensitively with word
# boundaries. When unset, the SIGNATURE_DUPLICATE check is disabled.
# ZAMMAD_BANNED_NAMES=Jane Doe,Jane

# Greeting that every reply body must contain (case-insensitive). When
# unset, the MISSING_GREETING check is disabled.
# ZAMMAD_REQUIRED_GREETING=Viele Grüße
